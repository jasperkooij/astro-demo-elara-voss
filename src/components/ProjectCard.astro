---
interface Props {
  title: string;
  description: string;
  tags: string[];
  year: number;
  link?: string;
}

const { title, description, tags, year, link } = Astro.props;
---

<article class="border border-border rounded-lg p-6 bg-surface hover:border-accent/50 transition-colors flex flex-col gap-4">
  <div class="flex items-start justify-between gap-4">
    <div>
      <span class="text-xs font-mono text-muted">{year}</span>
      <h3 class="text-lg font-semibold text-text mt-0.5 leading-snug">
        {title}
      </h3>
    </div>
    {
      link && (
        <a
          href={link}
          class="shrink-0 text-muted hover:text-accent transition-colors mt-1"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} (opens in new tab)`}
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5z"
            />
            <path
              fill-rule="evenodd"
              d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0v-5z"
            />
          </svg>
        </a>
      )
    }
  </div>

  <p class="text-muted text-sm leading-relaxed flex-1">
    {description}
  </p>

  <div class="flex flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="text-xs font-mono text-green bg-green/10 px-2 py-0.5 rounded">
          {tag}
        </span>
      ))
    }
  </div>
</article>
