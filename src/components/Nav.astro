---
const pathname = Astro.url.pathname;

const links = [
  { href: '/about/',    label: 'About'    },
  { href: '/work/',     label: 'Work'     },
  { href: '/services/', label: 'Services' },
  { href: '/blog/',     label: 'Blog'     },
];

const themes = [
  { id: 'espresso', color: '#fb923c', label: 'Espresso' },
  { id: 'studio',   color: '#7c3aed', label: 'Studio'   },
  { id: 'midnight', color: '#ff6b6b', label: 'Midnight' },
  { id: 'rose',     color: '#f43f5e', label: 'Rose'     },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="border-b border-border sticky top-0 z-50 bg-bg/95 backdrop-blur-sm">
  <nav
    class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-text font-semibold text-lg tracking-tight hover:text-accent transition-colors"
      aria-label="Elara Voss — home"
    >
      Elara Voss
    </a>

    <div class="flex items-center gap-4">
      <!-- Desktop nav links -->
      <ul class="hidden md:flex items-center gap-6">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`text-sm font-medium transition-colors hover:text-text ${
                isActive(href) ? 'text-accent' : 'text-muted'
              }`}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Separator -->
      <div class="hidden md:block h-4 w-px bg-border" aria-hidden="true"></div>

      <!-- Theme swatches -->
      <div class="flex items-center gap-1.5" role="group" aria-label="Colour theme">
        {themes.map(({ id, color, label }) => (
          <button
            data-theme-btn={id}
            aria-label={`${label} theme`}
            title={label}
            class="theme-swatch"
            style={`--sw: ${color}`}
          />
        ))}
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle-btn"
        class="md:hidden text-muted hover:text-text transition-colors p-1.5 -mr-1.5 rounded-md"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <rect x="2" y="4"  width="16" height="2" rx="1" />
          <rect x="2" y="9"  width="16" height="2" rx="1" />
          <rect x="2" y="14" width="16" height="2" rx="1" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div id="mobile-nav" class="hidden border-b border-border bg-surface md:hidden">
    <ul class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`block py-2 text-sm font-medium transition-colors hover:text-text ${
              isActive(href) ? 'text-accent' : 'text-muted'
            }`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .theme-swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: var(--sw);
    border: 0;
    padding: 0;
    cursor: pointer;
    flex-shrink: 0;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .theme-swatch:hover {
    transform: scale(1.25);
  }
  .theme-swatch[data-active] {
    transform: scale(1.15);
    box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 3.5px var(--color-text);
  }
  .theme-swatch:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 3.5px var(--color-accent);
  }
</style>

<script>
  const THEME_COLORS = {
    espresso: '#12100e',
    studio:   '#faf8f5',
    midnight: '#0d1526',
    rose:     '#110e0e',
  };

  let cleanup = () => {};

  function syncSwatches() {
    const current = document.documentElement.getAttribute('data-theme') || 'espresso';
    document.querySelectorAll('[data-theme-btn]').forEach((el) => {
      el.toggleAttribute('data-active', el.getAttribute('data-theme-btn') === current);
    });
  }

  function init() {
    // Tear down previous listeners before re-attaching (prevents duplicates)
    cleanup();
    const ac = new AbortController();
    const { signal } = ac;
    cleanup = () => ac.abort();

    const html = document.documentElement;
    const menu = document.getElementById('mobile-nav');
    const toggleBtn = document.getElementById('nav-toggle-btn');

    // Reset mobile menu state on every navigation
    menu?.classList.add('hidden');
    toggleBtn?.setAttribute('aria-expanded', 'false');

    toggleBtn?.addEventListener('click', () => {
      const open = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!open));
      menu?.classList.toggle('hidden', open);
    }, { signal });

    document.querySelectorAll('[data-theme-btn]').forEach((el) => {
      el.addEventListener('click', () => {
        const theme = el.getAttribute('data-theme-btn');
        if (!theme) return;
        html.classList.add('theme-transitioning');
        html.setAttribute('data-theme', theme);
        localStorage.setItem('ev-theme', theme);
        syncSwatches();
        const color = THEME_COLORS[theme as keyof typeof THEME_COLORS];
        document.querySelector('meta[name="theme-color"]')
          ?.setAttribute('content', color ?? '#12100e');
        setTimeout(() => html.classList.remove('theme-transitioning'), 300);
      }, { signal });
    });

    syncSwatches();
  }

  // Call immediately — astro:page-load fires before module scripts register on initial load
  init();
  document.addEventListener('astro:page-load', init);
</script>
