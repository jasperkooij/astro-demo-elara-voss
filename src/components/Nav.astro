---
const pathname = Astro.url.pathname;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/work/', label: 'Work' },
  { href: '/services/', label: 'Services' },
  { href: '/blog/', label: 'Blog' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="border-b border-border sticky top-0 z-50 bg-bg/95 backdrop-blur-sm">
  <nav
    class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-text font-semibold text-lg tracking-tight hover:text-accent transition-colors"
      aria-label="Elara Voss — home"
    >
      Elara Voss
    </a>

    <input
      type="checkbox"
      id="nav-toggle"
      class="sr-only peer"
      aria-hidden="true"
    />
    <label
      for="nav-toggle"
      class="md:hidden cursor-pointer text-muted hover:text-text transition-colors p-2 -mr-2"
      aria-label="Toggle navigation menu"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <rect x="2" y="4" width="16" height="2" rx="1" />
        <rect x="2" y="9" width="16" height="2" rx="1" />
        <rect x="2" y="14" width="16" height="2" rx="1" />
      </svg>
    </label>

    <ul
      class="hidden peer-checked:flex absolute top-16 left-0 right-0 flex-col bg-surface border-b border-border px-4 py-4 gap-1 md:static md:flex md:flex-row md:bg-transparent md:border-none md:px-0 md:py-0 md:gap-6 md:items-center"
      id="nav-menu"
    >
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`block py-2 md:py-0 text-sm font-medium transition-colors hover:text-text ${
                isActive(href) ? 'text-accent' : 'text-muted'
              }`}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
