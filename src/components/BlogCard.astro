---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-border rounded-lg p-6 bg-surface hover:border-accent/50 transition-colors">
  <div class="flex flex-wrap gap-2 mb-3">
    {
      tags.map((tag) => (
        <span class="text-xs font-mono text-accent bg-accent/10 px-2 py-0.5 rounded">
          {tag}
        </span>
      ))
    }
  </div>

  <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-accent transition-colors leading-snug">
    <a href={`/blog/${slug}/`} class="stretched-link">
      {title}
    </a>
  </h3>

  <p class="text-muted text-sm leading-relaxed mb-4 line-clamp-2">
    {description}
  </p>

  <div class="flex items-center justify-between">
    <time
      datetime={pubDate.toISOString()}
      class="text-xs text-muted font-mono"
    >
      {formattedDate}
    </time>
    <span class="text-accent text-sm font-medium" aria-hidden="true">
      Read &rarr;
    </span>
  </div>
</article>

<style>
  .stretched-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  article {
    position: relative;
  }
</style>
