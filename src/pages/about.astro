---
import { Picture } from 'astro:assets';
import profileImg from '../assets/images/profile.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://elaravoss.dev';
const pageUrl = `${siteUrl}/about/`;
const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': pageUrl,
  name: 'About Elara Voss — Senior Frontend Engineer',
  description: 'Elara Voss is a senior frontend engineer and design systems architect with 8 years of experience, based in Amsterdam. Learn about her background, skills, and engineering philosophy.',
  url: pageUrl,
  isPartOf: { '@id': `${siteUrl}/#website` },
  about: { '@id': `${siteUrl}/#person` },
};

const skills = [
  'Astro', 'React', 'TypeScript', 'CSS / Tailwind',
  'Design Systems', 'Figma', 'Node.js', 'Performance Auditing',
  'Web Accessibility', 'Test-Driven Development', 'Storybook', 'WebSockets',
];

const experience = [
  {
    role: 'Senior Frontend Engineer',
    company: 'Forma Labs',
    period: '2022 – present',
    start: '2022',
    description:
      'Leading frontend architecture across three product squads. Built the Meridian design system, established performance budgets, and reduced time-to-interactive by 60% across core user flows.',
  },
  {
    role: 'Frontend Engineer',
    company: 'Bloom Digital',
    period: '2019 – 2022',
    start: '2019',
    description:
      'Rebuilt the company\'s flagship SaaS product from a jQuery monolith to a React application. Introduced TypeScript, component testing with Vitest, and automated accessibility auditing.',
  },
  {
    role: 'Junior Developer',
    company: 'Pixel & Co',
    period: '2018 – 2019',
    start: '2018',
    description:
      'Built marketing sites and interactive landing pages for agency clients. First exposure to performance budgets and Core Web Vitals before they were a formal Google metric.',
  },
];

const principles = [
  {
    title: 'Performance is the feature',
    body: 'Speed is not a nice-to-have. A 1-second delay in page response causes a 7% reduction in conversions. I treat performance budgets as first-class product requirements, not afterthoughts.',
  },
  {
    title: 'Accessibility is not optional',
    body: 'WCAG compliance is the floor, not the ceiling. I build for keyboard navigation, screen readers, reduced motion, and high contrast from day one — because retrofitting accessibility is ten times harder than building it in.',
  },
  {
    title: 'Design and engineering must speak the same language',
    body: 'The gap between Figma and production is where quality dies. Design tokens, shared vocabulary, and tight designer-engineer collaboration are what close that gap. Design systems are the infrastructure for that conversation.',
  },
];
---

<BaseLayout
  title="About Elara Voss — Senior Frontend Engineer"
  description="Elara Voss is a senior frontend engineer and design systems architect with 8 years of experience, based in Amsterdam. Learn about her background, skills, and engineering philosophy."
>
  <script type="application/ld+json" set:html={JSON.stringify(webpageSchema)} slot="head" />
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    <section class="mb-20 grid md:grid-cols-[1fr_220px] gap-12 items-start">
      <div>
        <div class="flex items-center gap-4 mb-3 animate-fade-up">
          <p class="text-accent text-sm font-mono tracking-wide uppercase">About</p>
          <p class="text-xs font-mono text-muted">Last updated: May 2026</p>
        </div>
        <h1 class="text-4xl font-bold text-text mb-8 leading-tight animate-fade-up-d1">
          I make the web faster, more accessible, and more consistent.
        </h1>

      <div class="max-w-2xl space-y-5 text-muted leading-relaxed animate-fade-up-d2">
        <p>
          I&rsquo;m Elara Voss, a senior frontend engineer and design systems architect based in Amsterdam.
          Over the past 8 years I&rsquo;ve worked across agencies, startups, and scale-ups — building
          everything from marketing sites to real-time trading dashboards. My work sits at the intersection
          of engineering rigour and design sensibility.
        </p>
        <p>
          I specialise in Astro, React, and TypeScript, with a particular focus on performance
          engineering and design system architecture. I care deeply about Core Web Vitals, web
          accessibility, and the craft of writing component APIs that other engineers actually enjoy using.
        </p>
        <p>
          Before joining Forma Labs as a senior engineer in 2022, I spent three years at Bloom Digital
          helping transform a jQuery monolith into a modern React application, and a year before that
          building agency sites at Pixel &amp; Co, where I first learned to obsess over load times.
        </p>
        <p>
          I graduated with a BSc in Computer Science from TU Delft in 2018. Outside of work, I&rsquo;m
          a regular speaker at Amsterdam.js, an occasional open source contributor, and a very amateur
          cyclist.
        </p>
      </div>
      </div>

      <!-- Profile photo -->
      <div class="hidden md:flex justify-center animate-fade-in" aria-hidden="true">
        <div class="w-[220px] rounded-2xl overflow-hidden border border-border bg-surface">
          <Picture
            src={profileImg}
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            widths={[220, 440]}
            sizes="220px"
            alt="Elara Voss — Senior Frontend Engineer"
            loading="lazy"
            class="w-full h-auto block"
          />
        </div>
      </div>
    </section>

    <section class="mb-20 pt-12 border-t border-border">
      <h2 class="text-xl font-bold text-text mb-6">Skills &amp; Technologies</h2>
      <div class="flex flex-wrap gap-3">
        {
          skills.map((skill) => (
            <span class="px-3 py-1.5 bg-surface border border-border rounded-md text-sm text-text font-medium">
              {skill}
            </span>
          ))
        }
      </div>
    </section>

    <section class="mb-20 pt-12 border-t border-border">
      <h2 class="text-xl font-bold text-text mb-8">Experience</h2>
      <ol class="relative border-l border-border space-y-10 ml-4">
        {
          experience.map(({ role, company, period, start, description }) => (
            <li class="pl-8 relative">
              <div class="absolute -left-[5px] top-1.5 w-2.5 h-2.5 rounded-full bg-accent border-2 border-bg" />
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 mb-2">
                <h3 class="text-base font-semibold text-text">
                  {role}
                </h3>
                <span class="text-muted text-sm">at {company}</span>
              </div>
              <time
                class="text-xs font-mono text-muted"
                datetime={start}
              >
                {period}
              </time>
              <p class="text-muted text-sm leading-relaxed mt-2">{description}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="mb-20 pt-12 border-t border-border">
      <h2 class="text-xl font-bold text-text mb-8">Engineering Philosophy</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        {
          principles.map(({ title, body }) => (
            <div class="bg-surface border border-border rounded-lg p-6">
              <h3 class="text-base font-semibold text-accent mb-3">{title}</h3>
              <p class="text-muted text-sm leading-relaxed">{body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="pt-12 border-t border-border">
      <h2 class="text-xl font-bold text-text mb-6">Education</h2>
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-10 h-10 bg-surface border border-border rounded-lg flex items-center justify-center text-accent font-bold text-sm">
          TU
        </div>
        <div>
          <p class="text-text font-semibold">BSc Computer Science</p>
          <p class="text-muted text-sm">
            TU Delft — Delft, Netherlands
          </p>
          <time class="text-xs font-mono text-muted" datetime="2018">2014 – 2018</time>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
